# Copy this file to `.env` and adjust as needed. All variables are optional;
# the project runs fully offline with the defaults below.

# ---- LLM provider ----
# One of: echo | openai | gemini
# "echo" runs offline and returns an extractive, grounded answer (no API key).
RAG_LLM_PROVIDER=echo
RAG_LLM_MODEL=gpt-4o-mini
# RAG_OPENAI_API_KEY=sk-...
# RAG_GEMINI_API_KEY=...

# ---- Embeddings ----
# One of: huggingface | hashing
# "huggingface" (default) uses a real sentence-transformers model; the model is
# downloaded on first use. "hashing" needs no downloads (offline / CI).
RAG_EMBEDDING_BACKEND=huggingface
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Vector store ----
# One of: memory | chroma
RAG_VECTOR_STORE=memory
RAG_CHROMA_PATH=.chroma

# ---- Retrieval / chunking ----
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
